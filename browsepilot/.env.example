# LLM API (DeepSeek, OpenAI 兼容格式)
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_VISION_ENABLED=false

# MCP 服务器地址
MCP_SERVER_URL=http://localhost:8090/sse
MCP_SERVER_PORT=8090
MCP_MODE=sse

# 浏览器配置
BROWSER_HEADLESS=true
# BROWSER_CHANNEL: 留空使用 Playwright 内置 Chromium，设为 "msedge"/"chrome"/"chromium" 使用系统浏览器
BROWSER_CHANNEL=msedge
BROWSER_TIMEOUT=15000

# 允许的域名白名单（逗号分隔）
ALLOWED_DOMAINS=github.com,baidu.com,wikipedia.org

# 日志级别
LOG_LEVEL=INFO
