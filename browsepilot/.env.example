# LLM API (DeepSeek, OpenAI 兼容格式)
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Big model (main agent)
BIG_MODEL=deepseek-v4-flash
# BIG_MODEL_API_KEY=
# BIG_MODEL_BASE_URL=

# Small model (classify)
SMALL_MODEL=deepseek-chat
# SMALL_MODEL_API_KEY=
# SMALL_MODEL_BASE_URL=

LLM_VISION_ENABLED=false

# 默认搜索 URL（用户任务无明确 URL 时使用）
DEFAULT_SEARCH_URL=https://www.bing.com

# 浏览器配置
BROWSER_HEADLESS=true
# BROWSER_CHANNEL: 留空使用 Playwright 内置 Chromium，设为 "msedge"/"chrome"/"chromium" 使用系统浏览器
BROWSER_CHANNEL=msedge
BROWSER_TIMEOUT=15000

# 允许的域名白名单（逗号分隔）
ALLOWED_DOMAINS=github.com,baidu.com,wikipedia.org

# 日志级别
LOG_LEVEL=INFO

# BrowserPool
BROWSER_POOL_SIZE=8
BROWSER_POOL_PREWARM=2
BROWSER_MAX_AGE_MINUTES=30
BROWSER_MAX_REQUESTS=50
BROWSER_IDLE_TIMEOUT=10
BROWSER_ACQUIRE_TIMEOUT=30
MCP_TOOL_TIMEOUT=30
MCP_CONNECT_RETRIES=3
MAX_ACTIVE_SESSIONS=10
